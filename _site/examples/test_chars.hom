// test_chars.hom — Integration test for chars.rs (character classification)
//
// Exercises every exported function from chars.rs via the .hom → rustc pipeline:
//   is_alpha, is_alnum, is_digit, is_whitespace, is_newline
//
// Helpers inspect the FIRST character only — multi-char inputs are
// classified by their first char. is_alnum treats '_' as alnum to match
// Homun identifier continuation. Empty string returns false.
//
// Uses direct if/else + print instead of a check(cond, msg) helper to avoid
// the &str vs String mismatch: .hom emits string literals as &str but functions
// typed (str) in .hom generate String params in Rust.
//
// Compile + run (no external crate deps):
//   homunc runtime/test_chars.hom -o /tmp/test_chars.rs
//   rustc /tmp/test_chars.rs -o /tmp/test_chars && /tmp/test_chars
//
// Expected: all lines begin with "  ok:" — no "FAIL:" lines.

use chars

main := () -> _ {
  print("=== test_chars ===")

  // ── is_alpha ────────────────────────────────────────────────────────────────
  if (is_alpha("a")) {
    print("  ok: is_alpha lowercase 'a'")
  } else {
    print("FAIL: is_alpha lowercase 'a'")
  }
  if (is_alpha("Z")) {
    print("  ok: is_alpha uppercase 'Z'")
  } else {
    print("FAIL: is_alpha uppercase 'Z'")
  }
  if (is_alpha("hello")) {
    print("  ok: is_alpha multi-char string (first char alpha)")
  } else {
    print("FAIL: is_alpha multi-char string (first char alpha)")
  }
  if (not is_alpha("3")) {
    print("  ok: is_alpha false for digit '3'")
  } else {
    print("FAIL: is_alpha false for digit '3'")
  }
  if (not is_alpha(" ")) {
    print("  ok: is_alpha false for space")
  } else {
    print("FAIL: is_alpha false for space")
  }
  if (not is_alpha("")) {
    print("  ok: is_alpha false for empty string")
  } else {
    print("FAIL: is_alpha false for empty string")
  }

  // ── is_alnum ────────────────────────────────────────────────────────────────
  if (is_alnum("a")) {
    print("  ok: is_alnum letter 'a'")
  } else {
    print("FAIL: is_alnum letter 'a'")
  }
  if (is_alnum("9")) {
    print("  ok: is_alnum digit '9'")
  } else {
    print("FAIL: is_alnum digit '9'")
  }
  if (is_alnum("foo123")) {
    print("  ok: is_alnum multi-char string (first char alnum)")
  } else {
    print("FAIL: is_alnum multi-char string (first char alnum)")
  }
  if (is_alnum("_")) {
    print("  ok: is_alnum true for underscore (ident continuation)")
  } else {
    print("FAIL: is_alnum true for underscore (ident continuation)")
  }
  if (not is_alnum(" ")) {
    print("  ok: is_alnum false for space")
  } else {
    print("FAIL: is_alnum false for space")
  }
  if (not is_alnum("")) {
    print("  ok: is_alnum false for empty string")
  } else {
    print("FAIL: is_alnum false for empty string")
  }

  // ── is_digit ────────────────────────────────────────────────────────────────
  if (is_digit("0")) {
    print("  ok: is_digit '0'")
  } else {
    print("FAIL: is_digit '0'")
  }
  if (is_digit("9")) {
    print("  ok: is_digit '9'")
  } else {
    print("FAIL: is_digit '9'")
  }
  if (is_digit("123")) {
    print("  ok: is_digit multi-char string (first char digit)")
  } else {
    print("FAIL: is_digit multi-char string (first char digit)")
  }
  if (not is_digit("a")) {
    print("  ok: is_digit false for letter 'a'")
  } else {
    print("FAIL: is_digit false for letter 'a'")
  }
  if (not is_digit(" ")) {
    print("  ok: is_digit false for space")
  } else {
    print("FAIL: is_digit false for space")
  }
  if (not is_digit("")) {
    print("  ok: is_digit false for empty string")
  } else {
    print("FAIL: is_digit false for empty string")
  }

  // ── is_whitespace ───────────────────────────────────────────────────────────
  if (is_whitespace(" ")) {
    print("  ok: is_whitespace space")
  } else {
    print("FAIL: is_whitespace space")
  }
  if (is_whitespace("\t")) {
    print("  ok: is_whitespace tab")
  } else {
    print("FAIL: is_whitespace tab")
  }
  if (is_whitespace("   ")) {
    print("  ok: is_whitespace multi-char (first char space)")
  } else {
    print("FAIL: is_whitespace multi-char (first char space)")
  }
  if (not is_whitespace("a")) {
    print("  ok: is_whitespace false for letter 'a'")
  } else {
    print("FAIL: is_whitespace false for letter 'a'")
  }
  if (not is_whitespace("1")) {
    print("  ok: is_whitespace false for digit '1'")
  } else {
    print("FAIL: is_whitespace false for digit '1'")
  }
  if (not is_whitespace("")) {
    print("  ok: is_whitespace false for empty string")
  } else {
    print("FAIL: is_whitespace false for empty string")
  }

  // ── is_newline ──────────────────────────────────────────────────────────────
  if (is_newline("\n")) {
    print("  ok: is_newline true for '\\n'")
  } else {
    print("FAIL: is_newline true for '\\n'")
  }
  if (not is_newline(" ")) {
    print("  ok: is_newline false for space")
  } else {
    print("FAIL: is_newline false for space")
  }
  if (not is_newline("a")) {
    print("  ok: is_newline false for letter 'a'")
  } else {
    print("FAIL: is_newline false for letter 'a'")
  }
  if (not is_newline("")) {
    print("  ok: is_newline false for empty string")
  } else {
    print("FAIL: is_newline false for empty string")
  }

  print("=== done ===")
}
