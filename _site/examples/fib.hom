// ─── examples/fib.hom ───────────────────────────────────────────
// Demonstrates: recursion, if/else, break => value
use std

fib := (n: int) -> int {
  if (n <= 1) do { break => n }
  fib(n - 1) + fib(n - 2)
}

main := () -> _ {
  for i in range(10) do {
    print("fib(${i}) = ${fib(i)}")
  }
}
