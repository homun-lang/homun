// parser.hom — Recursive-descent Pratt parser → AST
//
// Uses:
//   parser_imp — token helpers (ps_peek_kind, ps_check, …), AST constructors,
//                Option helpers, split_block
//
// Thread-local state (pos, err, gensym_counter) lives here as @thread_local
// bindings; the thin wrappers (ps_advance, ps_save, …) are defined below.
// PARSE_TOKENS stays in parser_imp.rs (concrete Vec<Token> type required).
//
// Public API:
//   parse_program() -> @[Stmt]     — called from parser.rs wrapper

// ─── Thread-local parser state ───────────────────────────────────────────────

@thread_local
parse_pos ::= 0

@thread_local
parse_err ::= ""

@thread_local
gensym_counter ::= 0

// ─── State accessor wrappers ─────────────────────────────────────────────────

ps_pos := () -> int { parse_pos }

ps_advance := () -> _ {
  if (parse_err == "") { parse_pos ::= parse_pos + 1 }
}

ps_save := () -> int { parse_pos }

ps_restore := (p: int) -> _ { parse_pos ::= p }

ps_has_err := () -> bool { parse_err != "" }

ps_set_err := (msg: str) -> _ {
  if (parse_err == "") { parse_err ::= msg }
}

ps_gensym := (prefix: str) -> str {
  n := gensym_counter
  gensym_counter ::= gensym_counter + 1
  "${prefix}${n}"
}

use parser_imp

// ─── Entry point ────────────────────────────────────────────────────────────

parse_program := () -> @[Stmt] {
  stmts := @[]
  done := false
  at_top := true
  while (not done) {
    k := ps_peek_kind()
    if (k == "Eof" or k == "RBrace") {
      done := true
    } else {
      if (k == "At" and ps_peek_next_kind() == "Bang") {
        if (at_top) {
          ps_advance()
          body := ps_collect_attr_body()
          push(stmts, Stmt.InnerAttr(body))
        } else {
          ps_set_err("@! inner attribute must appear before any declarations")
          done := true
        }
      } else {
        if (k == "At" and ps_peek_next_kind() == "Ident") {
          // Collect one or more outer attrs: @ident...
          outer_attrs := @[]
          while (ps_check("At") and ps_peek_next_kind() == "Ident") {
            ps_advance()
            body := ps_collect_outer_attr_body()
            outer_attrs := outer_attrs + @[body]
          }
          // Expect a decl-starter after attrs
          k2 := ps_peek_kind()
          if (k2 == "Ident") {
            at_top := false
            push(stmts, parse_top_bind_attrs(outer_attrs))
          } else {
            ps_set_err("attribute must precede a struct, enum, or top-level binding")
            done := true
          }
        } else {
          if (k == "Use") {
            at_top := false
            push(stmts, parse_use())
          } else {
            if (k == "Ident") {
              at_top := false
              push(stmts, parse_top_bind())
            } else {
              done := true
            }
          }
        }
      }
    }
  }
  ps_expect("Eof")
  stmts
}

// ─── Top-level statements ───────────────────────────────────────────────────

parse_use := () -> Stmt {
  ps_expect("Use")
  path := parse_mod_path()
  Stmt.Use(path)
}

parse_mod_path := () -> @[str] {
  name := ps_advance_ident()
  if (ps_has_err()) {
    => @[]
  }
  path := @[name]
  if (ps_consume("DoubleColon")) {
    rest := parse_mod_path()
    path := vec_concat_strs(path, rest)
  }
  path
}

parse_top_bind := () -> Stmt {
  name := ps_advance_ident()
  ps_expect("Assign")
  k := ps_peek_kind()
  if (k == "Struct") {
    ps_advance()
    fields := parse_brace_fields()
    Stmt.StructDef(name, fields, @[])
  } else {
    if (k == "Enum") {
      ps_advance()
      variants := parse_brace_variants()
      Stmt.EnumDef(name, variants, @[])
    } else {
      rhs := parse_expr()
      Stmt.Bind(name, rhs, @[])
    }
  }
}

parse_top_bind_attrs := (attrs: @[str]) -> Stmt {
  name := ps_advance_ident()
  // @thread_local name ::= expr  →  Stmt::ThreadLocal
  if ("thread_local" in attrs) {
    ps_expect("MutAssign")
    rhs := parse_expr()
    => Stmt.ThreadLocal(name, rhs)
  }
  ps_expect("Assign")
  k := ps_peek_kind()
  if (k == "Struct") {
    ps_advance()
    fields := parse_brace_fields()
    Stmt.StructDef(name, fields, attrs)
  } else {
    if (k == "Enum") {
      ps_advance()
      variants := parse_brace_variants()
      Stmt.EnumDef(name, variants, attrs)
    } else {
      rhs := parse_expr()
      Stmt.Bind(name, rhs, attrs)
    }
  }
}

parse_brace_fields := () -> @[FieldDef] {
  ps_expect("LBrace")
  fields := @[]
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "RBrace") {
      done := true
    } else {
      if (k == "Ident") {
        name := ps_peek_ident()
        ps_advance()
        ps_expect("Colon")
        ty := parse_type_expr()
        ps_consume("Comma")
        push(fields, FieldDef { name: name, ty: some_type(ty) })
      } else {
        done := true
      }
    }
  }
  ps_expect("RBrace")
  fields
}

parse_brace_variants := () -> @[VariantDef] {
  ps_expect("LBrace")
  variants := @[]
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "RBrace") {
      done := true
    } else {
      if (k == "Ident") {
        name := ps_peek_ident()
        ps_advance()
        if (ps_check("LParen")) {
          ps_advance()
          // Named fields: Variant(field: Type, ...) — ident followed by colon
          is_named := ps_peek_kind() == "Ident" and ps_peek_next_kind() == "Colon"
          if (is_named) {
            fnames := @[]
            ftys := @[]
            fname := ps_advance_ident()
            ps_expect("Colon")
            fty := parse_type_expr()
            push(fnames, fname)
            push(ftys, fty)
            while (ps_consume("Comma")) {
              if (ps_check("RParen")) { break }
              fname2 := ps_advance_ident()
              ps_expect("Colon")
              fty2 := parse_type_expr()
              push(fnames, fname2)
              push(ftys, fty2)
            }
            ps_expect("RParen")
            ps_consume("Comma")
            push(variants, mk_variantdef_multi(name, fnames, ftys))
          } else {
            // Positional fields (single or multi)
            all_tys := @[parse_type_expr()]
            while (ps_consume("Comma")) {
              if (ps_check("RParen")) { break }
              push(all_tys, parse_type_expr())
            }
            ps_expect("RParen")
            ps_consume("Comma")
            if (len(all_tys) == 1) {
              push(variants, VariantDef { name: name, fields: @[(none, all_tys[0])] })
            } else {
              push(variants, mk_variantdef_positional(name, all_tys))
            }
          }
        } else {
          ps_consume("Comma")
          push(variants, VariantDef { name: name, fields: @[] })
        }
      } else {
        done := true
      }
    }
  }
  ps_expect("RBrace")
  variants
}

// ─── Block statements ───────────────────────────────────────────────────────

parse_block_stmts := () -> @[Stmt] {
  stmts := @[]
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "RBrace" or k == "Eof") {
      done := true
    } else {
      if (k == "FatArrow") {
        ps_advance()
        e := parse_expr()
        push(stmts, Stmt.Expression(mk_expr_early_return(e)))
      } else {
        if (k == "LBrace") {
          // Try struct destructure: {x: a, y: b} := expr
          sd_stmts := try_parse_struct_destruct()
          if (len(sd_stmts) > 0) {
            si := 0
            while (si < len(sd_stmts)) {
              push(stmts, sd_stmts[si])
              si := si + 1
            }
          } else {
            e := parse_expr()
            push(stmts, Stmt.Expression(e))
          }
        } else {
          if (k == "Ident") {
            push(stmts, parse_block_bind())
          } else {
            e := parse_expr()
            push(stmts, Stmt.Expression(e))
          }
        }
      }
    }
  }
  stmts
}

// ─── try_parse_struct_destruct ──────────────────────────────────────────────
// Try to parse {field: binding, ...} := expr
// Returns @[Stmt] (multiple Bind stmts) on success, or @[] on failure.
// Desugars: {x: a, y: b} := pos  →  _sd := pos; a := _sd.x; b := _sd.y

try_parse_struct_destruct := () -> @[Stmt] {
  saved := ps_save()

  // Expect {
  if (not ps_check("LBrace")) {
    => @[]
  }
  ps_advance()

  // Parse field:binding pairs
  fields := @[]
  bindings := @[]
  ok := true

  while (ok and not ps_check("RBrace")) {
    fk := ps_peek_kind()
    if (fk != "Ident") {
      ok := false
    }
    if (ok) {
      field := ps_peek_ident()
      ps_advance()
      if (not ps_check("Colon")) {
        ok := false
      }
      if (ok) {
        ps_advance()
        bk := ps_peek_kind()
        if (bk != "Ident") {
          ok := false
        }
        if (ok) {
          binding := ps_peek_ident()
          ps_advance()
          push(fields, field)
          push(bindings, binding)
          dummy := ps_consume("Comma")
        } else {}
      }
    }
  }

  if (not ok or len(fields) == 0) {
    ps_restore(saved)
    => @[]
  }

  // Expect }
  if (not ps_check("RBrace")) {
    ps_restore(saved)
    => @[]
  }
  ps_advance()

  // Expect :=
  if (not ps_check("Assign")) {
    ps_restore(saved)
    => @[]
  }
  ps_advance()

  // Parse the RHS expression
  rhs := parse_expr()

  // Desugar: _sd0 := rhs; binding := _sd0.field; ...
  result := @[]
  tmp_name := ps_gensym("_sd")
  push(result, Stmt.Bind(tmp_name, rhs, @[]))
  i := 0
  while (i < len(fields)) {
    field_expr := mk_expr_field(Expr.Var(tmp_name), fields[i])
    push(result, Stmt.Bind(bindings[i], field_expr, @[]))
    i := i + 1
  }
  result
}

parse_block_bind := () -> Stmt {
  saved := ps_save()
  k := ps_peek_kind()
  if (k != "Ident") {
    e := parse_expr()
    => Stmt.Expression(e)
  }
  name := ps_peek_ident()
  ps_advance()

  // Tuple bind: a, b := expr
  if (ps_check("Comma")) {
    names := @[name]
    while (ps_consume("Comma")) {
      nk := ps_peek_kind()
      if (nk == "Ident") {
        push(names, ps_peek_ident())
        ps_advance()
      } else {
        if (nk == "Underscore") {
          push(names, "_")
          ps_advance()
        } else {
          ps_restore(saved)
          e := parse_expr()
          => Stmt.Expression(e)
        }
      }
    }
    if (ps_check("Assign")) {
      ps_advance()
      rhs := parse_expr()
      pats := names_to_pats(names)
      => Stmt.BindPat(Pat.Tuple(pats), rhs)
    }
    if (ps_check("MutAssign")) {
      ps_advance()
      rhs := parse_expr()
      pats := names_to_pats(names)
      => Stmt.BindPatMut(Pat.Tuple(pats), rhs)
    }
    ps_restore(saved)
    e := parse_expr()
    => Stmt.Expression(e)
  }

  // Single bind: a := expr
  if (ps_check("Assign")) {
    ps_advance()
    rhs := parse_expr()
    => Stmt.Bind(name, rhs, @[])
  }
  if (ps_check("MutAssign")) {
    ps_advance()
    rhs := parse_expr()
    => Stmt.BindMut(name, rhs)
  }

  // Lvalue: expr[idx] := rhs  or  expr.field := rhs
  if (ps_check("LBracket") or ps_check("Dot")) {
    ps_restore(saved)
    lhs := parse_expr()
    if (ps_check("Assign")) {
      ps_advance()
      rhs := parse_expr()
      => Stmt.Assign(lhs, rhs)
    }
    => Stmt.Expression(lhs)
  }

  // Fallback: expression
  ps_restore(saved)
  e := parse_expr()
  Stmt.Expression(e)
}

parse_block_stmts_braced := () -> @[Stmt] {
  ps_expect("LBrace")
  stmts := parse_block_stmts()
  ps_expect("RBrace")
  stmts
}

// ─── Expressions (precedence chain) ─────────────────────────────────────────

parse_expr := () -> Expr {
  parse_pipe()
}

parse_pipe := () -> Expr {
  lhs ::= parse_or()
  while (ps_check("Pipe")) {
    ps_advance()
    rhs := parse_postfix()
    lhs ::= mk_expr_pipe(lhs, rhs)
  }
  lhs
}

parse_or := () -> Expr {
  lhs ::= parse_and()
  while (ps_check("Or")) {
    ps_advance()
    rhs := parse_and()
    lhs ::= mk_expr_binop("Or", lhs, rhs)
  }
  lhs
}

parse_and := () -> Expr {
  lhs ::= parse_not()
  while (ps_check("And")) {
    ps_advance()
    rhs := parse_not()
    lhs ::= mk_expr_binop("And", lhs, rhs)
  }
  lhs
}

parse_not := () -> Expr {
  if (ps_check("Not")) {
    ps_advance()
    e := parse_not()
    mk_expr_unop("Not", e)
  } else {
    parse_cmp()
  }
}

parse_cmp := () -> Expr {
  lhs := parse_add_sub()
  k := ps_peek_kind()
  if (k == "Eq") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Eq", lhs, rhs) }
  else { if (k == "Neq") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Neq", lhs, rhs) }
  else { if (k == "Lt") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Lt", lhs, rhs) }
  else { if (k == "Gt") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Gt", lhs, rhs) }
  else { if (k == "Le") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Le", lhs, rhs) }
  else { if (k == "Ge") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("Ge", lhs, rhs) }
  else { if (k == "In") { ps_advance()  rhs := parse_add_sub()  mk_expr_binop("In", lhs, rhs) }
  else { if (k == "Not") {
    if (ps_same_line()) {
      ps_advance()
      ps_expect("In")
      rhs := parse_add_sub()
      mk_expr_binop("NotIn", lhs, rhs)
    } else {
      lhs
    }
  } else {
    lhs
  }}}}}}}}
}

parse_add_sub := () -> Expr {
  lhs ::= parse_mul_div()
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "Plus") {
      ps_advance()
      rhs := parse_mul_div()
      lhs ::= mk_expr_binop("Add", lhs, rhs)
    } else {
      if (k == "Minus") {
        ps_advance()
        rhs := parse_mul_div()
        lhs ::= mk_expr_binop("Sub", lhs, rhs)
      } else {
        done := true
      }
    }
  }
  lhs
}

parse_mul_div := () -> Expr {
  lhs ::= parse_unary()
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "Star") {
      ps_advance()
      rhs := parse_unary()
      lhs ::= mk_expr_binop("Mul", lhs, rhs)
    } else {
      if (k == "Slash") {
        ps_advance()
        rhs := parse_unary()
        lhs ::= mk_expr_binop("Div", lhs, rhs)
      } else {
        if (k == "Percent") {
          ps_advance()
          rhs := parse_unary()
          lhs ::= mk_expr_binop("Mod", lhs, rhs)
        } else {
          done := true
        }
      }
    }
  }
  lhs
}

parse_unary := () -> Expr {
  if (ps_check("Minus")) {
    ps_advance()
    e := parse_unary()
    mk_expr_unop("Neg", e)
  } else {
    parse_postfix()
  }
}

parse_postfix := () -> Expr {
  e ::= parse_atom()
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "Dot") {
      ps_advance()
      fname := ps_advance_ident()
      if (ps_check("LParen")) {
        args := parse_arg_list()
        e ::= mk_expr_call(mk_expr_field(e, fname), args)
      } else {
        e ::= mk_expr_field(e, fname)
      }
    } else {
      if (k == "LBracket" and ps_same_line()) {
        ps_advance()
        // Slice or index
        ik := ps_peek_kind()
        if (ik == "Colon") {
          // Slice with no start: [:end] or [:end:step] or [:]
          ps_advance()
          to := parse_opt_slice_expr()
          step := if (ps_consume("Colon")) { parse_opt_slice_expr() } else { none_expr() }
          ps_expect("RBracket")
          e ::= mk_expr_slice(e, none_expr(), to, step)
        } else {
          idx := parse_expr()
          if (ps_check("Colon")) {
            // Slice with start: [start:end] or [start:end:step]
            ps_advance()
            to := parse_opt_slice_expr()
            step := if (ps_consume("Colon")) { parse_opt_slice_expr() } else { none_expr() }
            ps_expect("RBracket")
            e ::= mk_expr_slice(e, some_expr(idx), to, step)
          } else {
            // Index
            ps_expect("RBracket")
            e ::= mk_expr_index(e, idx)
          }
        }
      } else {
        if (k == "LParen" and ps_same_line()) {
          args := parse_arg_list()
          e ::= mk_expr_call(e, args)
        } else {
          if (k == "Question") {
            ps_advance()
            e ::= mk_expr_try_unwrap(e)
          } else {
            done := true
          }
        }
      }
    }
  }
  e
}

parse_opt_slice_expr := () -> Option<Expr> {
  k := ps_peek_kind()
  if (k == "RBracket" or k == "Colon") {
    none_expr()
  } else {
    some_expr(parse_expr())
  }
}

// ─── Atoms ──────────────────────────────────────────────────────────────────

parse_atom := () -> Expr {
  k := ps_peek_kind()
  if (k == "Int") {
    n := ps_peek_int()
    ps_advance()
    => Expr.Int(n)
  }
  if (k == "Float") {
    f := ps_peek_float()
    ps_advance()
    => Expr.Float(f)
  }
  if (k == "Bool") {
    b := ps_peek_bool()
    ps_advance()
    => Expr.Bool(b)
  }
  if (k == "Str") {
    s := ps_peek_str()
    ps_advance()
    => Expr.Str(s)
  }
  if (k == "Char") {
    c := ps_peek_char()
    ps_advance()
    => mk_expr_char_from_str(c)
  }
  if (k == "None") {
    ps_advance()
    => Expr.None
  }
  if (k == "LParen") {
    => parse_lambda_or_paren()
  }
  if (k == "At") {
    => parse_collection()
  }
  if (k == "If") {
    => parse_if_expr()
  }
  if (k == "Match") {
    => parse_match_expr()
  }
  if (k == "For") {
    => parse_for_expr()
  }
  if (k == "While") {
    => parse_while_expr()
  }
  if (k == "Break") {
    => parse_break_expr()
  }
  if (k == "Continue") {
    ps_advance()
    => Expr.Continue
  }
  if (k == "LBrace") {
    => parse_inline_block()
  }
  if (k == "Lt") {
    => parse_generic_lambda()
  }
  if (k == "Underscore") {
    ps_advance()
    => Expr.Var("_")
  }
  if (k == "Ident") {
    name := ps_peek_ident()
    ps_advance()
    if (ps_check("LBrace") and is_upper_first_str(name)) {
      fields := parse_struct_lit_fields()
      => Expr.Struct(some_str(name), fields)
    }
    => Expr.Var(name)
  }
  // Unknown token
  if (not ps_has_err()) {
    ps_set_err("Unexpected token: ${k}")
  }
  Expr.None
}

// ─── Lambda vs parenthesised expr ───────────────────────────────────────────

parse_lambda_or_paren := () -> Expr {
  saved := ps_save()
  lambda := try_parse_lambda()
  if (not ps_has_err()) {
    lambda
  } else {
    ps_clear_err()
    ps_restore(saved)
    // Parenthesised expr or tuple
    ps_expect("LParen")
    e := parse_expr()
    if (ps_check("Comma")) {
      ps_advance()
      rest := parse_expr_sep("RParen")
      ps_expect("RParen")
      items := @[e]
      items := vec_concat_exprs(items, rest)
      Expr.Tuple(items)
    } else {
      ps_expect("RParen")
      e
    }
  }
}

try_parse_lambda := () -> Expr {
  ps_expect("LParen")
  params := parse_param_list()
  ps_expect("RParen")
  if (not ps_check("Arrow")) {
    ps_set_err("not a lambda")
    => Expr.None
  }
  ps_advance()
  // Return type
  rk := ps_peek_kind()
  ret_ty := if (rk == "LBrace") {
    none_type()
  } else {
    if (rk == "Underscore") {
      ps_advance()
      none_type()
    } else {
      some_type(parse_type_expr())
    }
  }
  void_mark := if (rk == "Underscore") { some_type(TypeExpr.Void) } else { none_type() }
  stmts := parse_block_stmts_braced()
  ss, fe := split_block(stmts)
  mk_expr_lambda(params, ret_ty, void_mark, ss, fe)
}

parse_param_list := () -> @[Param] {
  if (ps_check("RParen")) {
    @[]
  } else {
    params := @[parse_one_param()]
    while (ps_consume("Comma")) {
      if (ps_check("RParen")) {
        break
      }
      push(params, parse_one_param())
    }
    params
  }
}

parse_one_param := () -> Param {
  k := ps_peek_kind()
  if (k == "Underscore") {
    ps_advance()
    => Param { name: "_", ty: none_type(), mutable: false, default: none_expr() }
  }
  name := ps_advance_ident()
  // name::Type — mutable param
  if (ps_consume("DoubleColon")) {
    ty := parse_type_expr()
    => Param { name: name, ty: some_type(ty), mutable: true, default: none_expr() }
  }
  // name:=expr — default param
  if (ps_consume("Assign")) {
    default := parse_expr()
    => Param { name: name, ty: none_type(), mutable: false, default: some_expr(default) }
  }
  // name:Type — typed param
  if (ps_consume("Colon")) {
    ty := parse_type_expr()
    => Param { name: name, ty: some_type(ty), mutable: false, default: none_expr() }
  }
  // name — untyped param
  Param { name: name, ty: none_type(), mutable: false, default: none_expr() }
}

parse_arg_list := () -> @[Expr] {
  ps_expect("LParen")
  args := parse_expr_sep("RParen")
  ps_expect("RParen")
  args
}

parse_expr_sep := (stop: str) -> @[Expr] {
  if (ps_check(stop)) {
    @[]
  } else {
    items := @[parse_expr()]
    while (ps_consume("Comma")) {
      if (ps_check(stop)) {
        break
      }
      push(items, parse_expr())
    }
    items
  }
}

// ─── Collections ────────────────────────────────────────────────────────────

parse_collection := () -> Expr {
  ps_expect("At")
  k := ps_peek_kind()
  if (k == "LBracket") { parse_list() }
  else { if (k == "LBrace") { parse_dict_or_set() }
  else {
    ps_set_err("Expected [ or { after @")
    Expr.None
  }}
}

parse_list := () -> Expr {
  ps_expect("LBracket")
  if (ps_check("RBracket")) {
    ps_advance()
    Expr.List(@[])
  } else {
    items := parse_expr_sep("RBracket")
    ps_expect("RBracket")
    Expr.List(items)
  }
}

parse_dict_or_set := () -> Expr {
  ps_expect("LBrace")
  if (ps_check("RBrace")) {
    // @{} — empty dict (backward compat)
    ps_advance()
    Expr.Dict(new_expr_pairs())
  } else {
    // Parse first expression, then peek: Colon → dict, Comma/RBrace → set
    first := parse_expr()
    if (ps_check("Colon")) {
      // Dict: @{key: val, ...}
      ps_advance()
      v := parse_expr()
      pairs ::= new_expr_pairs()
      pairs ::= push_expr_pair(pairs, first, v)
      while (ps_consume("Comma")) {
        if (ps_check("RBrace")) { break }
        k2 := parse_expr()
        ps_expect("Colon")
        v2 := parse_expr()
        pairs ::= push_expr_pair(pairs, k2, v2)
      }
      ps_expect("RBrace")
      Expr.Dict(pairs)
    } else {
      // Set: @{a, b, ...}
      items := @[first]
      while (ps_consume("Comma")) {
        if (ps_check("RBrace")) { break }
        push(items, parse_expr())
      }
      ps_expect("RBrace")
      Expr.Set(items)
    }
  }
}

parse_struct_lit_fields := () -> @[(str, Expr)] {
  ps_expect("LBrace")
  fields ::= new_name_expr_pairs()
  done := false
  while (not done) {
    k := ps_peek_kind()
    if (k == "RBrace") {
      done := true
    } else {
      if (k == "Ident") {
        name := ps_peek_ident()
        ps_advance()
        ps_expect("Colon")
        v := parse_expr()
        ps_consume("Comma")
        fields ::= push_name_expr_pair(fields, name, v)
      } else {
        done := true
      }
    }
  }
  ps_expect("RBrace")
  fields
}

// ─── Control flow ───────────────────────────────────────────────────────────

parse_if_expr := () -> Expr {
  ps_expect("If")
  ps_expect("LParen")
  cond := parse_expr()
  ps_expect("RParen")
  then_stmts := parse_block_stmts_braced()
  ts, te := split_block(then_stmts)
  else_clause := if (ps_check("Else")) {
    ps_advance()
    else_stmts := parse_block_stmts_braced()
    es, ee := split_block(else_stmts)
    some_else(es, ee)
  } else {
    no_else()
  }
  mk_expr_if(cond, ts, te, else_clause)
}

parse_match_expr := () -> Expr {
  ps_expect("Match")
  scrut := parse_expr()
  ps_expect("LBrace")
  arms := @[]
  while (not ps_check("RBrace") and not ps_has_err()) {
    push(arms, parse_match_arm())
  }
  ps_expect("RBrace")
  mk_expr_match(scrut, arms)
}

parse_match_arm := () -> MatchArm {
  first_pat := parse_pat()
  // Or-pattern: collect alternatives separated by | (Pipe token)
  pat := if (ps_check("Pipe")) {
    pats := @[first_pat]
    while (ps_check("Pipe")) {
      ps_advance()
      push(pats, parse_pat())
    }
    Pat.Or(pats)
  } else {
    first_pat
  }
  guard := if (ps_check("If")) {
    ps_advance()
    some_expr(parse_expr())
  } else {
    none_expr()
  }
  ps_expect("Arrow")
  body := parse_expr()
  MatchArm { pat: pat, guard: guard, body: body }
}

parse_more_pats := () -> @[Pat] {
  pats := @[parse_pat()]
  while (ps_check("Comma")) {
    ps_advance()
    push(pats, parse_pat())
  }
  pats
}

parse_pat := () -> Pat {
  k := ps_peek_kind()
  if (k == "Underscore") {
    ps_advance()
    => Pat.Wild
  }
  if (k == "None") {
    ps_advance()
    => Pat.None
  }
  if (k == "Ident") {
    name := ps_peek_ident()
    ps_advance()
    if (ps_check("Dot")) {
      ps_advance()
      vname := ps_advance_ident()
      full := "${name}.${vname}"
      if (ps_check("LParen")) {
        ps_advance()
        if (ps_check("RParen")) {
          ps_advance()
          => Pat.Enum(full, @[])
        }
        epats := @[parse_pat()]
        while (ps_consume("Comma")) {
          if (ps_check("RParen")) { break }
          push(epats, parse_pat())
        }
        ps_expect("RParen")
        if (len(epats) == 1) {
          => Pat.Enum(full, @[epats[0]])
        }
        => Pat.Enum(full, epats)
      }
      => Pat.Enum(full, @[])
    }
    if (ps_check("LParen") and ps_same_line()) {
      ps_advance()
      if (ps_check("RParen")) {
        ps_advance()
        => Pat.Enum(name, @[])
      }
      epats := @[parse_pat()]
      while (ps_consume("Comma")) {
        if (ps_check("RParen")) { break }
        push(epats, parse_pat())
      }
      ps_expect("RParen")
      if (len(epats) == 1) {
        => Pat.Enum(name, @[epats[0]])
      }
      => Pat.Enum(name, epats)
    }
    => Pat.Var(name)
  }
  if (k == "Int") {
    n := ps_peek_int()
    ps_advance()
    => Pat.Lit(Expr.Int(n))
  }
  if (k == "Float") {
    f := ps_peek_float()
    ps_advance()
    => Pat.Lit(Expr.Float(f))
  }
  if (k == "Bool") {
    b := ps_peek_bool()
    ps_advance()
    => Pat.Lit(Expr.Bool(b))
  }
  if (k == "Str") {
    s := ps_peek_str()
    ps_advance()
    => Pat.Lit(Expr.Str(s))
  }
  if (k == "Char") {
    c := ps_peek_char()
    ps_advance()
    => Pat.Lit(mk_expr_char_from_str(c))
  }
  if (k == "Minus") {
    ps_advance()
    nk := ps_peek_kind()
    if (nk == "Int") {
      n := ps_peek_int()
      ps_advance()
      => Pat.Lit(Expr.Int(neg_i64(n)))
    }
    if (nk == "Float") {
      f := ps_peek_float()
      ps_advance()
      => Pat.Lit(Expr.Float(neg_f64(f)))
    }
    ps_set_err("Expected number after '-' in pattern")
    => Pat.Wild
  }
  if (k == "LParen") {
    ps_advance()
    if (ps_check("RParen")) {
      ps_advance()
      => Pat.Tuple(@[])
    }
    pats := @[parse_pat()]
    while (ps_consume("Comma")) {
      if (ps_check("RParen")) {
        break
      }
      push(pats, parse_pat())
    }
    ps_expect("RParen")
    => Pat.Tuple(pats)
  }
  if (not ps_has_err()) {
    ps_set_err("Expected pattern, got ${k}")
  }
  Pat.Wild
}

// ─── Loops ──────────────────────────────────────────────────────────────────

parse_for_expr := () -> Expr {
  ps_expect("For")
  k := ps_peek_kind()
  var_name := if (k == "Underscore") {
    ps_advance()
    "_"
  } else {
    ps_advance_ident()
  }
  ps_expect("In")
  iter := parse_expr()
  stmts := parse_block_stmts_braced()
  ss, fe := split_block(stmts)
  mk_expr_for(var_name, iter, ss, some_expr(fe))
}

parse_while_expr := () -> Expr {
  ps_expect("While")
  ps_expect("LParen")
  cond := parse_expr()
  ps_expect("RParen")
  stmts := parse_block_stmts_braced()
  ss, fe := split_block(stmts)
  mk_expr_while(cond, ss, some_expr(fe))
}

parse_break_expr := () -> Expr {
  ps_expect("Break")
  mk_expr_break_none()
}

parse_inline_block := () -> Expr {
  stmts := parse_block_stmts_braced()
  ss, fe := split_block(stmts)
  mk_expr_block(ss, fe)
}

// ─── Types ──────────────────────────────────────────────────────────────────

parse_type_expr := () -> TypeExpr {
  k := ps_peek_kind()
  if (k == "At") {
    ps_advance()
    ak := ps_peek_kind()
    if (ak == "LBracket") {
      ps_advance()
      ty := parse_type_expr()
      ps_expect("RBracket")
      => mk_type_list(ty)
    }
    if (ak == "LBrace") {
      ps_advance()
      kty := parse_type_expr()
      ps_expect("Colon")
      vty := parse_type_expr()
      ps_expect("RBrace")
      => mk_type_dict(kty, vty)
    }
    if (ak == "LParen") {
      ps_advance()
      ty := parse_type_expr()
      ps_expect("RParen")
      => mk_type_set(ty)
    }
    => TypeExpr.Infer
  }
  if (k == "LParen") {
    ps_advance()
    types := @[parse_type_expr()]
    while (ps_consume("Comma")) {
      push(types, parse_type_expr())
    }
    ps_expect("RParen")
    => TypeExpr.Tuple(types)
  }
  if (k == "Underscore") {
    ps_advance()
    => TypeExpr.Void
  }
  if (k == "Ident") {
    name := ps_peek_ident()
    ps_advance()
    if (ps_check("Lt")) {
      ps_advance()
      params := @[parse_type_expr()]
      while (ps_consume("Comma")) {
        push(params, parse_type_expr())
      }
      ps_expect("Gt")
      => TypeExpr.Generic(name, params)
    }
    => TypeExpr.Name(name)
  }
  TypeExpr.Infer
}

// ─── Generic lambda ──────────────────────────────────────────────────────────
// Parses `<T: Trait + Trait, U>(params) -> ret { body }`

parse_generic_lambda := () -> Expr {
  ps_expect("Lt")
  generics := parse_generic_param_list()
  ps_expect("Gt")
  ps_expect("LParen")
  params := parse_param_list()
  ps_expect("RParen")
  if (not ps_check("Arrow")) {
    ps_set_err("expected -> after generic lambda params")
    => Expr.None
  }
  ps_advance()
  rk := ps_peek_kind()
  ret_ty := if (rk == "LBrace") {
    none_type()
  } else {
    if (rk == "Underscore") {
      ps_advance()
      none_type()
    } else {
      some_type(parse_type_expr())
    }
  }
  void_mark := if (rk == "Underscore") { some_type(TypeExpr.Void) } else { none_type() }
  stmts := parse_block_stmts_braced()
  ss, fe := split_block(stmts)
  mk_expr_lambda_generics(generics, params, ret_ty, void_mark, ss, fe)
}

parse_generic_param_list := () -> @[str] {
  result := @[]
  name := ps_advance_ident()
  g_str := if (ps_consume("Colon")) {
    first_bound := ps_advance_ident()
    bounds := @[first_bound]
    while (ps_check("Plus")) {
      ps_advance()
      push(bounds, ps_advance_ident())
    }
    name + ": " + join(bounds, " + ")
  } else {
    name
  }
  push(result, g_str)
  while (ps_consume("Comma")) {
    if (ps_check("Gt")) { break }
    name2 := ps_advance_ident()
    g_str2 := if (ps_consume("Colon")) {
      b1 := ps_advance_ident()
      bounds2 := @[b1]
      while (ps_check("Plus")) {
        ps_advance()
        push(bounds2, ps_advance_ident())
      }
      name2 + ": " + join(bounds2, " + ")
    } else {
      name2
    }
    push(result, g_str2)
  }
  result
}
